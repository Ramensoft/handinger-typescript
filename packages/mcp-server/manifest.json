{
  "dxt_version": "0.2",
  "name": "@ramensoft/handinger-mcp",
  "version": "0.7.3",
  "description": "The official MCP Server for the Handinger API",
  "author": {
    "name": "Handinger",
    "email": "support@handinger.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramensoft/handinger-typescript.git"
  },
  "homepage": "https://github.com/ramensoft/handinger-typescript/tree/main/packages/mcp-server#readme",
  "documentation": "https://docs.handinger.com",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/index.js"
      ],
      "env": {
        "HANDINGER_API_KEY": "${user_config.HANDINGER_API_KEY}"
      }
    }
  },
  "user_config": {
    "HANDINGER_API_KEY": {
      "title": "api_key",
      "description": "",
      "required": true,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": [
    "api"
  ]
}
